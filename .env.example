# Copy to .env for local runs. On Render, set these as real environment
# variables on the Cron Job service instead (Settings -> Environment) --
# do not commit a real .env.
#
# Supabase -> Project Settings -> Database -> Connection string -> URI.
# Use the SESSION POOLER string (port 5432 or 6543, host contains
# "pooler.supabase.com"), not the direct connection -- cron jobs open a
# fresh short-lived connection each run, which pgbouncer session mode
# handles cleanly.
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxxxxxx:[email protected]:5432/postgres
