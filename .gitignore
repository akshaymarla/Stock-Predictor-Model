# Local database and runtime state -- not meant to be committed
data/*.db
data/*checkpoint*.json
logs/
__pycache__/
*.pyc
.DS_Store
**/.DS_Store

# screenerScraper.py's downloaded BSE ticker/token cache (public metadata,
# not secrets, but a runtime artifact re-fetched daily -- not source code)
src/tokens/
# same cache, but lands at the repo root instead of src/tokens/ when the
# fetch is invoked from run_nightly.sh (which cd's to the repo root) --
# a real cwd-relative-path inconsistency in screenerScraper.py/
# screener_common.py, not yet fixed at the source; ignoring both
# locations until it is
tokens/
models/artifacts/

# models/reports/ is gitignored -- full verbose reports are large/ephemeral --
# EXCEPT models/reports/archive/, a small compact-summary exception so
# analytical history survives rebuilds (docs/reports_archive_and_shortlist_spec.md Part A)
models/reports/*
!models/reports/archive/
!models/reports/archive/**

# models/shortlists/ -- weekly_shortlist.py's per-run output (dated JSON/MD
# files, re-generated every run) -- same reasoning as models/reports/: the
# compact archive summary (models/reports/archive/) is what's meant to
# survive long-term, not every individual weekly run's full output.
models/shortlists/

# frontend/data.js, frontend/universe.js -- generated by
# src/export_screener_data.py, re-run on demand (live/current-day
# screener data, per frontend-screener-spec.md Section 10 -- explicitly
# out of scope for historical views). The frontend source
# (index.html/styles.css/app.js) is real, tracked code; these files are
# snapshots of live scoring/price output, same "regenerated, not meant
# to survive rebuilds" status as models/shortlists/.
frontend/data.js
frontend/universe.js

# models/lots/ -- every "batch" of frozen picks ever made (src/freeze_lot.py),
# kept permanently ON DISK per explicit instruction ("we still store them
# in our folders") but not in git -- same reasoning as models/shortlists/:
# these are large, accumulating, machine-generated snapshots, not source.
# The record survives as long as the local models/lots/ directory does;
# nothing here is meant to be recovered from git history.
models/lots/
